<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Merged with the generated Info.plist (GENERATE_INFOPLIST_FILE stays on).
	     Holds only keys that build settings can't express. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.leonan.threewood</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>threewood</string>
			</array>
		</dict>
	</array>
	<!-- Standard HTTPS only — skips the export-compliance question on upload. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>
